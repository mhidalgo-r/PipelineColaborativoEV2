# ============================================
# IMAGEN BASE
# ============================================

FROM python:3.11-slim

# ============================================
# DIRECTORIO DE TRABAJO
# ============================================

WORKDIR /app

# ============================================
# COPIAR ARCHIVOS
# ============================================

COPY requirements.txt .

# ============================================
# INSTALAR DEPENDENCIAS
# ============================================

RUN pip install --no-cache-dir -r requirements.txt

# ============================================
# COPIAR PROYECTO
# ============================================

COPY . .

# ============================================
# EJECUTAR PIPELINE
# ============================================

CMD ["python", "scripts/load/loading_data.py"]